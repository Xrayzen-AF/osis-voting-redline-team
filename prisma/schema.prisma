generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

// ── AUTH SCHEMA ──────────────────────────────────────────────────────────────

model users {
  instance_id                 String?  @db.Uuid
  id                          String   @id @db.Uuid
  email                       String?  @db.VarChar(255)
  created_at                  DateTime? @db.Timestamptz(6)
  is_sso_user                 Boolean  @default(false)
  is_anonymous                Boolean  @default(false)

  @@schema("auth")
}

// ── PUBLIC SCHEMA ────────────────────────────────────────────────────────────

model kelas {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama_kelas  String        @unique
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  credentials credentials[]
  siswa       siswa[]

  @@schema("public")
}

model siswa {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama        String
  nis         String?       @unique
  kelas_id    String?       @db.Uuid
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  credentials credentials[]
  kelas       kelas?        @relation(fields: [kelas_id], references: [id], onDelete: Cascade)

  @@index([kelas_id], map: "idx_siswa_kelas")
  @@schema("public")
}

model credentials {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  siswa_id        String?   @db.Uuid
  kelas_id        String?   @db.Uuid
  pin             String    @unique
  sudah_digunakan Boolean?  @default(false)
  used_at         DateTime? @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  kelas           kelas?    @relation(fields: [kelas_id], references: [id], onDelete: Cascade)
  siswa           siswa?    @relation(fields: [siswa_id], references: [id], onDelete: Cascade)
  votes           votes[]

  @@index([kelas_id], map: "idx_credentials_kelas")
  @@index([pin], map: "idx_credentials_pin")
  @@index([siswa_id], map: "idx_credentials_siswa")
  @@schema("public")
}

model paslon {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nomor_urut Int       @unique
  nama_ketua String
  nama_wakil String
  visi       String?
  misi       String?
  foto_url   String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  votes      votes[]

  @@schema("public")
}

model votes {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  credential_id String?      @db.Uuid
  paslon_id     String       @db.Uuid
  voted_at      DateTime     @default(now()) @db.Timestamptz(6)
  credentials   credentials? @relation(fields: [credential_id], references: [id], onDelete: SetNull)
  paslon        paslon       @relation(fields: [paslon_id], references: [id], onDelete: Cascade)

  @@schema("public")
}
